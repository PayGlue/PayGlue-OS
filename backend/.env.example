# PayGlue Backend — local development env vars
# Copy this file to .env and fill in the values.
# Never commit .env to git.

# ---------------------------------------------------------------
# Required in production (RuntimeError at startup if missing)
# ---------------------------------------------------------------

# Django secret key — used for session signing and webhook HMAC.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-generate-a-random-50-char-string

# ---------------------------------------------------------------
# Core Django
# ---------------------------------------------------------------

# Set to 1 for local dev (enables debug pages and auto-reload).
# Must be 0 in production.
DJANGO_DEBUG=1

# Comma-separated list of allowed hosts.
# Default covers localhost and payglue.io subdomains.
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------
# Database (choose one)
# ---------------------------------------------------------------

# Option A: full connection URL
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ghost_glue

# Option B: individual vars (docker-compose default)
PGDATABASE=ghost_glue
PGUSER=postgres
PGPASSWORD=postgres
PGHOST=localhost
PGPORT=5432

# ---------------------------------------------------------------
# Redis / Celery
# ---------------------------------------------------------------

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---------------------------------------------------------------
# Supabase Auth (required for login)
# ---------------------------------------------------------------

# kid of the ES256 signing key — NOT the JWT secret itself.
# Find it in Supabase Dashboard > Settings > API > JWT Settings.
SUPABASE_JWT_SECRET=

# JWKS endpoint (used if JWKS_KEYS is not set).
SUPABASE_JWKS_URL=

# Inline JWKS JSON — set this to avoid DNS lookups at startup.
# SUPABASE_JWKS_KEYS={"keys":[...]}

# ---------------------------------------------------------------
# Webhook endpoint tokens
# ---------------------------------------------------------------

# Simple global token (single-tenant dev setups).
WEBHOOK_ENDPOINT_TOKEN=dev-token

# JSON map for multi-tenant: {"tenant-slug": {"polar": "token", ...}}
# WEBHOOK_ENDPOINT_TOKENS=

# Set to 1 to allow the global token to match any tenant (dev only).
WEBHOOK_ALLOW_GLOBAL_ENDPOINT_TOKEN=1

# ---------------------------------------------------------------
# Credential encryption
# ---------------------------------------------------------------

# AES key for encrypting stored Ghost/provider credentials in the DB.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# ---------------------------------------------------------------
# Polar (optional — only needed if testing Polar webhooks locally)
# ---------------------------------------------------------------

# POLAR_SANDBOX_API_KEY=
# POLAR_SANDBOX_ORGANIZATION_ID=
# POLAR_API_KEY=
# POLAR_ORGANIZATION_ID=

# ---------------------------------------------------------------
# Misc dev settings
# ---------------------------------------------------------------

# Emails that bypass the invite gate in dev.
DEV_BYPASS_EMAILS=dev@payglue.io

# Set to 0 to disable the Prefinery invite gate locally.
PREFINERY_INVITE_GATE_ENABLED=0

# Internal API secret (used for service-to-service calls).
# INTERNAL_API_SECRET=
