# Webhook endpoint token — used by the API proxy to authenticate inbound webhooks.
# Set to a long random string (e.g. openssl rand -base64 32).
# WEBHOOK_ALLOW_GLOBAL_ENDPOINT_TOKEN=1 lets this single token work for all tenants.
# This is acceptable for single-operator deployments where the Cloudflare Worker uses one
# shared token. The per-provider HMAC signatures (Polar, LS, PayPal) are the primary
# security layer; this token prevents direct access to the Django webhook endpoint.
# For multi-operator deployments, configure per-tenant tokens via WEBHOOK_ENDPOINT_TOKENS
# and set WEBHOOK_ALLOW_GLOBAL_ENDPOINT_TOKEN=0.
WEBHOOK_ALLOW_GLOBAL_ENDPOINT_TOKEN=0
WEBHOOK_ENDPOINT_TOKEN=change-me-use-openssl-rand-base64-32

PREFINERY_INVITATION_DECODER_KEY=<set-locally>
PREFINERY_INVITATION_SHORTCODE_LENGTH=10
PREFINERY_INVITE_GATE_ENABLED=1
