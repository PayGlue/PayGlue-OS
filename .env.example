# PayGlue-OS — self-host configuration.
# Copy to .env and fill in. Every value here is read by backend settings.py;
# names must match exactly.

# --- Required ---------------------------------------------------------------

# Django. The dev server falls back to an insecure key when DJANGO_DEBUG=1;
# production (DJANGO_DEBUG=0) refuses to boot without a real one.
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=change-me-use-openssl-rand-base64-48
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-api-hostname.example

# Postgres + Redis. Note: there is no REDIS_URL -- Celery reads these two.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ghost_glue
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Encrypts stored provider credentials at rest (Fernet).
CREDENTIAL_ENCRYPTION_KEY=change-me-use-openssl-rand-base64-32

# Auth (Supabase or any compatible JWKS issuer). The backend verifies the
# dashboard's ES256 tokens against this. SUPABASE_JWKS_KEYS may hold the JWKS
# JSON inline to skip the network fetch on every cold start.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWKS_KEYS={"keys":[...]}

# Webhook ingestion. A long random string; WEBHOOK_ALLOW_GLOBAL_ENDPOINT_TOKEN=1
# lets the single token work for all tenants, which is fine for a
# single-operator deployment. Provider HMAC signatures remain the primary layer.
WEBHOOK_ENDPOINT_TOKEN=change-me-use-openssl-rand-base64-32
WEBHOOK_ALLOW_GLOBAL_ENDPOINT_TOKEN=1

# --- Optional ---------------------------------------------------------------

# Outbound email (member notifications, one-time codes). Without a key, set
# EMAIL_BACKEND to Django's console backend for development.
# RESEND_API_KEY=
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_REDIRECT_TO= # staging installs: reroute EVERY outbound mail to one address

# Admin API access to the auth project (account deletion, user provisioning).
# SUPABASE_SERVICE_ROLE_KEY=

# --- Frontend (build-time, frontend/.env) ------------------------------------
# VITE_API_BASE_URL=
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-publishable-key
